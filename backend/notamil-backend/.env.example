# Variáveis de ambiente — Redato backend
# Copie pra .env e preencha. .env é gitignored.

# ────────────────────────────────────────────────────
# Anthropic
# ────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ────────────────────────────────────────────────────
# Twilio Sandbox (Fase A)
# Console: https://console.twilio.com
# ────────────────────────────────────────────────────
TWILIO_ACCOUNT_SID=AC...
TWILIO_AUTH_TOKEN=...
TWILIO_WHATSAPP_NUMBER=whatsapp:+14155238886
TWILIO_VALIDATE_SIGNATURE=1

# ────────────────────────────────────────────────────
# Banco de dados
# ────────────────────────────────────────────────────
# Postgres do portal (M1+). Comece local via docker-compose.
# DATABASE_URL=postgresql://redato:redato@localhost:5433/redato_portal_dev

# Postgres local via Homebrew (alternativa ao docker-compose):
# DATABASE_URL=postgresql://danielfrechiani@localhost:5432/redato_portal_dev

# SQLite legado (Fase A, mantido pra backward-compat até M4 migrar bot).
# Caminho relativo ao backend/. Default já é este — não precisa setar.
DATABASE_URL_SQLITE=sqlite:///data/whatsapp/redato.db

# ────────────────────────────────────────────────────
# Pipeline Redato (Fase A)
# ────────────────────────────────────────────────────
REDATO_DEV_OFFLINE=1
REDATO_DEV_PERSIST=0
REDATO_SCHEMA_FLAT=1
REDATO_ENSEMBLE=1
REDATO_SELF_CRITIQUE=1
REDATO_TWO_STAGE=1
REDATO_CLAUDE_MODEL=claude-opus-4-7
# REDATO_MISSION_MODEL=  # vazio = default por modo

# ────────────────────────────────────────────────────
# OpenAI (FT grader OF14 + Diagnóstico cognitivo Fase 2)
# ────────────────────────────────────────────────────
# OPENAI_API_KEY=sk-proj-...

# OF14 grader (FT). Override do modelo via REDATO_FT_MODEL.
# Backend: "ft" usa GPT-FT, "claude" volta pro Sonnet 4.6 v2.
# REDATO_OF14_BACKEND=ft

# Diagnóstico cognitivo (Fase 2 — gera envios.diagnostico).
# Default ON; setar "false" pra rollback rápido se algo quebrar.
REDATO_DIAGNOSTICO_HABILITADO=true
# Modelo do diagnóstico (default abaixo, GPT-4.1 base — não FT).
REDATO_DIAGNOSTICO_MODELO=gpt-4.1-2025-04-14
# Path do YAML de descritores (40 INEP-aligned). Default cobre dev
# local (relativo à raiz do repo) E Docker (/app/docs/...). Override
# só se rodar de path não-padrão.
# REDATO_DIAGNOSTICO_YAML=/abs/path/descritores.yaml
